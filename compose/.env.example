# Host port mapping for the Docker stack (ports exposed on the HOST machine).
# Copy to compose/.env and adjust. `scripts/init-runtime.sh` creates this for you.
APP_PORT=8080
DATA_PORT=9000
PRELABEL_PORT=8100

# Optional: forwarded into the prelabel container as HOST_DASHSCOPE_API_KEY.
# Leave empty unless you use the Alibaba DashScope ASR provider.
DASHSCOPE_API_KEY=
