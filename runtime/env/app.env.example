APP_ENV=dev

# SQLite database (mounted under runtime/data for persistence)
DB_URL=sqlite:////runtime/data/db/app.sqlite
RUNTIME_AUDIO_DIR=/runtime/data/audio

# !! CHANGE THIS to a long random string in production !!
SESSION_SECRET=dev_secret_please_change

# Audio source the app syncs recordings from (your own ingest/receiver server)
CUSTOMER_SERVER_URL=http://localhost:9000/

# Pre-label (ASR) service
ASR_PROVIDER=none
PRELABEL_SERVICE_URL=http://prelabel-service:8100
PRELABEL_PIPELINE_VERSION=mvp-mock-v1
PRELABEL_ALLOW_REPEAT=true
PRELABEL_ACTIVE_JOB_STALE_SECONDS=7200
ASR_VAD_THRES=15
