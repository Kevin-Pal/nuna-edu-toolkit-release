PRELABEL_PIPELINE_VERSION=mvp-asr-v1

# ASR provider: mock | dashscope_qwen3_asr_flash
# Default to `mock` so the stack runs with no external credentials.
PRELABEL_ASR_PROVIDER=mock

# DashScope (Alibaba Cloud Model Studio) settings — only used when provider is dashscope_*.
# Leave the key empty here; provide it via the host env var DASHSCOPE_API_KEY instead.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_ASR_MODEL=qwen3-asr-flash

# Optional ASR options
PRELABEL_ASR_LANGUAGE=zh
PRELABEL_ASR_ENABLE_ITN=false

# Storage / concurrency
PRELABEL_ASR_STORE_RAW_RESPONSE=false
PRELABEL_ENABLE_MOCK_SED_RESULT=false
PRELABEL_MAX_CONCURRENT_JOBS=2
PRELABEL_ASR_MAX_WORKERS=3
